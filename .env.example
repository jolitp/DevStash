# Neon PostgreSQL connection string (serverless).
# Use the DEVELOPMENT branch URL here while working locally; the production
# branch URL is configured separately in the deployment environment.
# Copy this file to `.env` and fill in real values (never commit `.env`).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/devstash?sslmode=require"

# Password for the seeded demo user (dev only). Defaults to "12345678" when
# unset. The seed script (`pnpm db:seed`) is for local/dev databases only —
# never run it against a shared or staging database.
SEED_DEMO_PASSWORD="12345678"

# NextAuth v5 (Auth.js). AUTH_SECRET signs the session JWT — generate one with
# `openssl rand -base64 33` (or `npx auth secret`). AUTH_GITHUB_ID / _SECRET come
# from a GitHub OAuth App (Settings → Developer settings → OAuth Apps); set the
# callback URL to http://localhost:3000/api/auth/callback/github for local dev.
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Resend — transactional email (verification links on registration). Get a key
# from https://resend.com (API Keys). RESEND_API_KEY is required to send email.
RESEND_API_KEY=""
# Sender address. Defaults to "DevStash <onboarding@resend.dev>", which works
# without domain verification but only delivers to your own Resend account email
# in test mode. Use a verified-domain sender in production.
EMAIL_FROM="DevStash <onboarding@resend.dev>"

# Absolute base URL used to build verification links. Optional in local dev
# (falls back to the request origin, i.e. http://localhost:3000). Set this in
# deployment so links point at the real domain, e.g. https://devstash.app
# AUTH_URL="http://localhost:3000"

# Toggle email verification for email/password sign-up & sign-in. ENABLED BY
# DEFAULT (secure) — leave unset to require verification. Set to "false" to
# disable: new accounts are created already-verified (no email sent) and the
# sign-in gate stops blocking unverified users. Useful while Resend has no
# verified domain (the shared onboarding@resend.dev sender only delivers to your
# own account). GitHub OAuth is unaffected either way.
# 
# inverted from course
# EMAIL_VERIFICATION_ENABLED="false"

# Upstash Redis — rate limiting for the auth endpoints (login, register, forgot
# / reset password, resend verification). Create a database at
# https://console.upstash.com and copy its REST URL + token. OPTIONAL in local
# dev: when either var is unset, rate limiting is skipped entirely (fails open),
# so auth still works without an Upstash project. Set both in deployment.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""