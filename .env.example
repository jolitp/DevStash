# Neon PostgreSQL connection string (serverless).
# Use the DEVELOPMENT branch URL here while working locally; the production
# branch URL is configured separately in the deployment environment.
# Copy this file to `.env` and fill in real values (never commit `.env`).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/devstash?sslmode=require"

# Password for the seeded demo user (dev only). Defaults to "12345678" when
# unset. The seed script (`pnpm db:seed`) is for local/dev databases only —
# never run it against a shared or staging database.
SEED_DEMO_PASSWORD="12345678"

# NextAuth v5 (Auth.js). AUTH_SECRET signs the session JWT — generate one with
# `openssl rand -base64 33` (or `npx auth secret`). AUTH_GITHUB_ID / _SECRET come
# from a GitHub OAuth App (Settings → Developer settings → OAuth Apps); set the
# callback URL to http://localhost:3000/api/auth/callback/github for local dev.
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""